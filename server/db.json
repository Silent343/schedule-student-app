  "quizzes": [
    {
      "id": 1,
      "title": "Derivadas",
      "subject": "math",
      "questions": [
        {
          "id": "der-1",
          "prompt": "¿Cuál es la derivada de f(x) = x³?",
          "options": [
            {
              "key": "a",
              "label": "3x²"
            },
            {
              "key": "b",
              "label": "x²"
            },
            {
              "key": "c",
              "label": "3x"
            },
            {
              "key": "d",
              "label": "x³/3"
            }
          ],
          "correctKey": "a",
          "explanation": "Por la regla de la potencia: d/dx(xⁿ) = n·xⁿ⁻¹."
        },
        {
          "id": "der-2",
          "prompt": "¿Cuál es la derivada de f(x) = sen(x)?",
          "options": [
            {
              "key": "a",
              "label": "-sen(x)"
            },
            {
              "key": "b",
              "label": "cos(x)"
            },
            {
              "key": "c",
              "label": "-cos(x)"
            },
            {
              "key": "d",
              "label": "tan(x)"
            }
          ],
          "correctKey": "b",
          "explanation": "La derivada de sen(x) es cos(x)."
        },
        {
          "id": "der-3",
          "prompt": "¿Cuál es la derivada de una constante c?",
          "options": [
            {
              "key": "a",
              "label": "c"
            },
            {
              "key": "b",
              "label": "1"
            },
            {
              "key": "c",
              "label": "0"
            },
            {
              "key": "d",
              "label": "x"
            }
          ],
          "correctKey": "c",
          "explanation": "La derivada de cualquier constante es 0."
        }
      ]
    },
    {
      "id": 2,
      "title": "Logaritmos",
      "subject": "math",
      "questions": [
        {
          "id": "log-1",
          "prompt": "¿Cuánto vale log₂(8)?",
          "options": [
            {
              "key": "a",
              "label": "2"
            },
            {
              "key": "b",
              "label": "3"
            },
            {
              "key": "c",
              "label": "4"
            },
            {
              "key": "d",
              "label": "8"
            }
          ],
          "correctKey": "b",
          "explanation": "2³ = 8, por lo tanto log₂(8) = 3."
        },
        {
          "id": "log-2",
          "prompt": "¿A qué equivale log(a·b)?",
          "options": [
            {
              "key": "a",
              "label": "log(a) · log(b)"
            },
            {
              "key": "b",
              "label": "log(a) − log(b)"
            },
            {
              "key": "c",
              "label": "log(a) + log(b)"
            },
            {
              "key": "d",
              "label": "log(a) / log(b)"
            }
          ],
          "correctKey": "c",
          "explanation": "Propiedad del producto: log(a·b) = log(a) + log(b)."
        },
        {
          "id": "log-3",
          "prompt": "¿Cuánto vale ln(1)?",
          "options": [
            {
              "key": "a",
              "label": "0"
            },
            {
              "key": "b",
              "label": "1"
            },
            {
              "key": "c",
              "label": "e"
            },
            {
              "key": "d",
              "label": "indefinido"
            }
          ],
          "correctKey": "a",
          "explanation": "ln(1) = 0 porque e⁰ = 1."
        }
      ]
    },
    {
